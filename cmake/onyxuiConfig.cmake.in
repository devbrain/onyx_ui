@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Required dependencies
find_dependency(failsafe REQUIRED)

# Optional dependencies (YAML themes)
set(_onyxui_yaml_themes @NEUTRINO_ONYX_UI_ENABLE_YAML_THEMES@)
if(_onyxui_yaml_themes)
    find_dependency(fkYAML REQUIRED)
    find_dependency(reflectcpp REQUIRED)
endif()

# Backend library dependencies. These are reconstituted here so that
# the backend link targets installed into onyxuiTargets.cmake (e.g.
# onyxui::onyxui_sdlpp_backend) resolve their BUILD_INTERFACE deps
# via normal find_package machinery at consume-time. If the consumer
# did not build against the same backends or didn't install sdlpp /
# termbox2 themselves, find_dependency fails with a clear message.
set(_onyxui_has_backend_sdlpp @NEUTRINO_ONYX_UI_BUILD_BACKEND_SDLPP@)
set(_onyxui_has_backend_conio @NEUTRINO_ONYX_UI_BUILD_BACKEND_CONIO@)
if(_onyxui_has_backend_sdlpp)
    find_dependency(sdlpp QUIET)
endif()
if(_onyxui_has_backend_conio)
    find_dependency(termbox2 QUIET)
endif()

# Load exported targets (core `onyxui::onyxui` interface target plus
# any backend libraries that were built — `onyxui::onyxui_sdlpp_backend`,
# `onyxui::onyxui_conio_backend`).
#
# Backend libraries carry the implementation of consumer-facing APIs
# like `onyxui::simple::app_window` and `onyxui::simple::run()`, so
# consumers who use the simple shell must link the appropriate backend
# library (`onyxui::onyxui_sdlpp_backend` for the sdlpp shell,
# `onyxui::onyxui_conio_backend` for the conio shell).
include("${CMAKE_CURRENT_LIST_DIR}/onyxuiTargets.cmake")

# Backward-compatible alias so existing consumers using
# `neutrino::onyxui` continue to link correctly.
if(NOT TARGET neutrino::onyxui)
    add_library(neutrino::onyxui ALIAS onyxui::onyxui)
endif()

# Legacy unnamespaced alias — keep until consumers have migrated.
if(NOT TARGET onyxui)
    add_library(onyxui ALIAS onyxui::onyxui)
endif()

check_required_components(onyxui)
